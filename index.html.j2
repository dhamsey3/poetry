<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Poems for the shadow, the dream, and the returning self.">
  <meta id="themeColorMeta" name="theme-color" content="#fbf7ed">
  <title>{{ site_title or "Torchborne" }}</title>
  {% set STATIC = static_base or './static/' %}
  {% set ASSET_VERSION = generated_at_iso or generated_at or '1' %}
  <link rel="stylesheet" href="{{ STATIC }}tailwind-ui.css?v={{ ASSET_VERSION }}">
  <link rel="stylesheet" href="{{ STATIC }}styles.css?v={{ ASSET_VERSION }}">
  <script>
    (function () {
      try {
        var saved = localStorage.getItem('torchborne-theme');
        var theme = saved === 'dark' || saved === 'light'
          ? saved
          : (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (_) {}
    })();
  </script>
</head>
<body>
  <a class="skip-link" href="#postsGrid">Skip to poems</a>
  <noscript>
    <div class="noscript-banner" role="alert">JavaScript is disabled. You can still read Torchborne directly on <a href="{{ POSTS_BASE }}">Substack</a>.</div>
  </noscript>

  <div class="reading-progress" id="readingProgress" aria-hidden="true"><span></span></div>

  <header class="site-header" id="appHeader">
    <div class="site-header__inner">
      <a class="brand" href="#" data-route="home" aria-label="Torchborne home">
        <svg class="brand__mark" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5Z"/></svg>
        <span>Torchborne</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="nav-link" href="#about" data-route="about">About</a>
        <button class="icon-button" id="themeToggle" type="button" aria-label="Use dark theme" aria-pressed="false">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
        <a class="button button--subscribe" href="{{ SUBSCRIBE_URL }}" data-subscribe>Subscribe</a>
      </nav>
    </div>
  </header>

  <main id="mainContent">
    <section class="home-view" id="homeView" aria-labelledby="homeTitle">
      <div class="page-shell">
        <header class="hero">
          <svg class="hero__flame" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5Z"/></svg>
          <p class="eyebrow">Shadow · Dream · Return</p>
          <h1 id="homeTitle">Poems for the shadow, the dream, and the returning self</h1>
          <p class="hero__intro">A small flame for what waits beneath the quiet. Read slowly, and follow whatever word keeps glowing after you leave.</p>

          <div class="discovery" aria-label="Find a poem">
            <label class="search-field" for="searchInput">
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
              <span class="visually-hidden">Search poems</span>
              <input id="searchInput" type="search" autocomplete="off" placeholder="Search poems, symbols, and themes">
            </label>
            <div class="filter-row" id="moodFilters" aria-label="Filter by mood">
              <button class="filter-chip is-active" type="button" data-mood="all" aria-pressed="true">All poems</button>
              <button class="filter-chip" type="button" data-mood="shadow" aria-pressed="false">Shadow</button>
              <button class="filter-chip" type="button" data-mood="dream" aria-pressed="false">Dream</button>
              <button class="filter-chip" type="button" data-mood="return" aria-pressed="false">Return</button>
            </div>
            <div class="filter-row filter-row--tags" id="tagFilters" aria-label="Filter by tag" hidden></div>
          </div>
        </header>

        {% if featured_ebook %}
        <aside class="ebook-spotlight" id="ebookSpotlight" aria-labelledby="ebookTitle">
          {% if featured_ebook.cover %}<img class="ebook-spotlight__cover" src="{{ featured_ebook.cover }}" alt="Cover of {{ featured_ebook.title }}" loading="lazy">{% endif %}
          <div class="ebook-spotlight__copy">
            <p class="eyebrow">{{ featured_ebook.tag or 'Featured collection' }}</p>
            <h2 id="ebookTitle">{{ featured_ebook.title }}</h2>
            <p>{{ featured_ebook.description }}</p>
            {% if featured_ebook.note %}<p class="ebook-spotlight__note">{{ featured_ebook.note }}</p>{% endif %}
            <div class="action-row">
              <a class="button button--primary" href="{{ featured_ebook.url }}" target="_blank" rel="noopener">{{ featured_ebook.ctaText }}</a>
              <button class="text-button" type="button" data-share="{{ featured_ebook.url | urlencode }}" data-title="{{ featured_ebook.title }}">{{ featured_ebook.shareText }}</button>
            </div>
          </div>
        </aside>
        {% endif %}

        <section class="poem-library" aria-labelledby="libraryTitle">
          <div class="section-heading">
            <div>
              <p class="eyebrow">The archive</p>
              <h2 id="libraryTitle">Choose what glows</h2>
            </div>
            <p class="result-summary" id="resultSummary" role="status" aria-live="polite">Preparing the poems…</p>
          </div>

          <div class="status-state" id="statusMessage" role="status" aria-live="polite">
            <span class="status-state__flame" aria-hidden="true"></span>
            <p>Gathering the latest poems…</p>
          </div>
          <div class="posts-grid" id="postsGrid" aria-live="polite" hidden></div>
          <div class="empty-state" id="emptyState" hidden>
            <h3>No poem is glowing here yet</h3>
            <p>Try another word or clear the active filters.</p>
            <button class="button button--secondary" id="clearFilters" type="button">Clear filters</button>
          </div>
          <button class="button button--secondary load-more" id="loadMore" type="button" hidden>Load more poems</button>
        </section>
      </div>
    </section>

    <section class="reader-view" id="readerView" aria-labelledby="readerTitle" hidden>
      <div class="reader-shell">
        <button class="back-link" id="readerBack" type="button">← All poems</button>
        <article class="reader-article">
          <header class="reader-header">
            <div class="reader-meta" id="readerMeta"></div>
            <div class="reader-tools" aria-label="Reading controls">
              <button class="icon-button reader-size" type="button" data-reader-dec aria-label="Decrease poem text size">A−</button>
              <output id="readerScale" aria-live="polite">100%</output>
              <button class="icon-button reader-size" type="button" data-reader-inc aria-label="Increase poem text size">A+</button>
            </div>
            <h1 id="readerTitle"></h1>
          </header>
          <div class="reader-body" id="readerBody"></div>
          <footer class="reader-actions">
            <button class="text-button" id="readerShare" type="button">Share poem</button>
            <a class="text-button" id="readerSource" href="{{ POSTS_BASE }}" target="_blank" rel="noopener">Open on Substack ↗</a>
          </footer>
        </article>
        <nav class="reader-pagination" aria-label="Adjacent poems">
          <button class="reader-next" id="previousPost" type="button"></button>
          <button class="reader-next reader-next--forward" id="nextPost" type="button"></button>
        </nav>
        <section class="related" aria-labelledby="relatedTitle">
          <div class="section-heading section-heading--compact">
            <div>
              <p class="eyebrow">Keep reading</p>
              <h2 id="relatedTitle">Whatever glows next</h2>
            </div>
          </div>
          <div class="posts-grid posts-grid--related" id="relatedGrid"></div>
        </section>
      </div>
    </section>

    <section class="about-view" id="aboutView" aria-labelledby="aboutTitle" hidden>
      <div class="about-shell">
        <button class="back-link" type="button" data-route="home">← All poems</button>
        <p class="eyebrow">About Torchborne</p>
        <h1 id="aboutTitle">A place for language that listens back</h1>
        <p class="about-lede">Torchborne gathers poems and reflections that move through longing, memory, faith, desire, grief, wonder, and the quieter rooms of the self.</p>
        <p>The name carries the image of a small flame: not a spotlight, not a performance, but enough light to walk a little deeper. Some pieces feel like prayers. Some feel like dreams. Some are honest attempts to name what is difficult to hold.</p>
        <div class="about-themes">
          <article><p class="eyebrow">Shadow</p><h2>Meet what is hidden</h2><p>Making room for the unfinished, difficult, and unspoken.</p></article>
          <article><p class="eyebrow">Dream</p><h2>Follow the symbol</h2><p>Listening to images, wonder, faith, and strange inner weather.</p></article>
          <article><p class="eyebrow">Return</p><h2>Come back gently</h2><p>Returning to tenderness, body, spirit, hope, and voice.</p></article>
        </div>
        <aside class="about-cta">
          <h2>New poems arrive quietly</h2>
          <p>No noise and no fixed schedule—just the work when it is ready.</p>
          <a class="button button--subscribe" href="{{ SUBSCRIBE_URL }}" data-subscribe>Subscribe for new poems</a>
        </aside>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <a class="brand brand--small" href="#" data-route="home" aria-label="Torchborne home">
        <svg class="brand__mark" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5Z"/></svg>
        <span>Torchborne</span>
      </a>
      <p>© {{ generated_at.year if generated_at else 2026 }} · Made with care.</p>
      <nav aria-label="Footer navigation">
        <a href="#about" data-route="about">About</a>
        <a href="{{ POSTS_BASE }}" target="_blank" rel="noopener">Substack</a>
        <a href="https://instagram.com/versesvibez" target="_blank" rel="noopener">Instagram</a>
      </nav>
    </div>
  </footer>

  <dialog class="subscribe-dialog" id="subscribeDialog" aria-labelledby="subscribeTitle" aria-describedby="subscribeDescription">
    <button class="dialog-close" type="button" data-dialog-close aria-label="Close subscription dialog">×</button>
    <svg class="hero__flame" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5Z"/></svg>
    <p class="eyebrow">Stay near the flame</p>
    <h2 id="subscribeTitle">New poems, when they are ready</h2>
    <p id="subscribeDescription">Receive new work in your inbox—no noise and no fixed schedule.</p>
    <a class="button button--subscribe" href="{{ SUBSCRIBE_URL }}">Continue to Substack</a>
  </dialog>

  <script id="initialPostsData" type="application/json">{{ (posts or []) | tojson }}</script>
  <script id="appConfig" type="application/json">{{ {
    'feedUrl': feed_url,
    'proxyUrl': rss_proxy_url,
    'publicUrl': POSTS_BASE,
    'subscribeUrl': SUBSCRIBE_URL,
    'rss2jsonApiKey': rss2json_api_key,
    'maxItems': max_items or 50
  } | tojson }}</script>
  <script>
    /* Kept as a small pure compatibility helper for the existing ebook regression tests. */
    const FEATURED_EBOOK = {{ (featured_ebook or {}) | tojson }};
    function prepareFeatured(){
      const config = FEATURED_EBOOK || {};
      return {
        ...config,
        poemHtml(poem = '') {
          const escapeHtml = (str = '') => String(str)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
          const normalized = String(poem).replace(/\r\n?/g, '\n').replace(/^\n|\n$/g, '');
          const lines = normalized.split('\n');
          const stanzas = [];
          let current = [];
          lines.forEach((line) => {
            if (!line.trim()) {
              if (current.length) { stanzas.push(current); current = []; }
              stanzas.push([]);
            } else current.push(line);
          });
          if (current.length) stanzas.push(current);
          return stanzas.map((stanza) => {
            if (!stanza.length) return '<p><br></p>';
            const body = stanza.map((line) => {
              const leading = (line.match(/^[ \t]*/) || [''])[0].replace(/\t/g, '    ').length;
              return '&nbsp;'.repeat(leading) + escapeHtml(line.trimStart());
            }).join('<br>');
            return `<p>${body}</p>`;
          }).join('');
        }
      };
    }
  </script>
  <script src="{{ STATIC }}app.js?v={{ ASSET_VERSION }}" defer></script>
</body>
</html>
